<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>ChronoStateVB</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionExplicit>On</OptionExplicit>
    <OptionStrict>On</OptionStrict>
    <OptionInfer>On</OptionInfer>

    <!-- NuGet Package Metadata -->
    <PackageId>ChronoStateVB</PackageId>
    <Version>1.0.0</Version>
    <Authors>Pac-Dessert1436</Authors>
    <Company></Company>
    <Description>Game state management toolkit for VB.NET — parallel background computation with
      double buffering, and event-driven rewind/undo with checkpointing.</Description>
    <PackageTags>
      game-development;vbnet;rewind;undo;double-buffering;parallel-computation;state-management;chrono</PackageTags>
    <PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryType>git</RepositoryType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>